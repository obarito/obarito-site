# Analytics + heatmaps (optional). When unset, nothing loads and no third-party
# requests fire - safe for local dev and preview deploys. Set real values in the
# Vercel project (Settings -> Environment Variables), Production scope.

# GA4 measurement id - traffic analytics + Google Ads conversion import.
# Find it in Google Analytics -> Admin -> Data streams -> your web stream.
NEXT_PUBLIC_GA_ID=

# Microsoft Clarity project id - heatmaps + session replay (free, unlimited).
# Find it in clarity.microsoft.com -> your project -> Settings -> Overview.
NEXT_PUBLIC_CLARITY_ID=
